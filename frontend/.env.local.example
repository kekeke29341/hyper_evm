NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
# Prefer Chainlink RPC on Vercel/serverless (official testnet RPC may TLS-reset)
NEXT_PUBLIC_TESTNET_RPC=https://rpcs.chain.link/hyperevm/testnet
NEXT_PUBLIC_MAINNET_RPC=https://rpc.hyperliquid.xyz/evm
# 31337 = Anvil local | 998 = HyperEVM testnet | 999 = HyperEVM mainnet
NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337
# Baked at build time — use false on public Production (see docs/vercel.md)
NEXT_PUBLIC_ADMIN_ENABLED=false
# Invite-only preview: true + comma-separated allowlist (debug builds: leave false)
NEXT_PUBLIC_WALLET_GATE_ENABLED=false
NEXT_PUBLIC_ALLOWED_WALLETS=
# Get free ID at https://cloud.reown.com (allow *.vercel.app)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Li.FI (optional — works without API key; register integrator at https://docs.li.fi)
NEXT_PUBLIC_LIFI_INTEGRATOR=hyperpool
LIFI_INTEGRATOR=hyperpool
# LIFI_API_KEY=your_key_if_rate_limited

# Vercel: copy frontend/.env.vercel.example → Vercel Dashboard env vars
# Never commit PRIVATE_KEY — see docs/vercel.md
