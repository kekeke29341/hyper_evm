# Vercel / testnet production defaults — copy to Vercel Environment Variables
# See docs/vercel.md for full setup guide

NEXT_PUBLIC_DEFAULT_CHAIN_ID=998
NEXT_PUBLIC_TESTNET_RPC=https://rpcs.chain.link/hyperevm/testnet
NEXT_PUBLIC_MAINNET_RPC=https://rpc.hyperliquid.xyz/evm
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Public site: false | Preview-only admin: true on Preview env in Vercel UI
NEXT_PUBLIC_ADMIN_ENABLED=false

# Invite-only access (all pages). Debug/testnet: false | Closed beta: true + allowlist
NEXT_PUBLIC_WALLET_GATE_ENABLED=false
NEXT_PUBLIC_ALLOWED_WALLETS=

# https://cloud.reown.com — add *.vercel.app to allowed domains
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

NEXT_PUBLIC_LIFI_INTEGRATOR=hyperpool
LIFI_INTEGRATOR=hyperpool
